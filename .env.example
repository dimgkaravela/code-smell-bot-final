GITHUB_TOKEN=
REPOSITORY=dimgkaravela/code-smell-bot
PR_NUMBER=1
POST_COMMENT=false
MAX_FILES=0
DEBUG_SMELLS=true
ANALYSIS_SCOPE=diff
FETCH_CONTENTS=true
FETCH_RELATED_FILES=true
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MAX_FILES_PER_CHUNK=4
LLM_MAX_PATCH_CHARS=18000
MAX_FILE_CONTENT_CHARS=12000
MAX_RELATED_FILES_PER_FILE=2
MAX_RELATED_FILE_CHARS=4000

# Optional LLM generation controls
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1200
LLM_TOP_P=0.95
LLM_TOP_K=40
LLM_CANDIDATE_COUNT=1
